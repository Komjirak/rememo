import 'package:google_generative_ai/google_generative_ai.dart';

class GeminiService {
  // 🔑 여기에 Google AI Studio에서 발급받은 API 키를 입력하세요
  // https://aistudio.google.com/app/apikey
  static const String _apiKey = 'AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX';
  
  // 📌 실제 사용 예시:
  // static const String _apiKey = 'AIzaSyDXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX';
  
  // ⚠️ 주의사항:
  // 1. API 키는 절대 GitHub에 커밋하지 마세요
  // 2. .gitignore에 gemini_service.dart를 추가하는 것을 권장합니다
  // 3. 프로덕션 배포 시에는 환경 변수나 Firebase Remote Config 사용을 권장합니다
  
  static GenerativeModel? _model;
  
  static GenerativeModel get model {
    _model ??= GenerativeModel(
      model: 'gemini-2.0-flash-exp',
      apiKey: _apiKey,
      generationConfig: GenerationConfig(
        temperature: 0.7,
        topP: 0.95,
        maxOutputTokens: 500,
      ),
    );
    return _model!;
  }

  // ... 나머지 코드 ...
}
