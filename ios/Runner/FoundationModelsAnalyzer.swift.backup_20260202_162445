import Foundation
import NaturalLanguage
import CoreGraphics

// MARK: - Data Structures
struct DetectedData: Codable {
    let urls: [String]
    let phoneNumbers: [String]
    let emails: [String]
}

struct AnalysisResult: Codable {
    let title: String
    let explanation: String
    let summary: String
    let insights: [String]
    let tags: [String]
    let contentType: String
    let refinedText: String
    let detectedData: DetectedData
    let provider: String
    
    func toDict() -> [String: Any] {
        return [
            "title": title,
            "summary": explanation,  // UI에서 explanation 사용
            "insights": insights,
            "tags": tags,
            "contentType": contentType,
            "refinedText": refinedText,
            "detectedData": [
                "urls": detectedData.urls,
                "phoneNumbers": detectedData.phoneNumbers,
                "emails": detectedData.emails
            ],
            "analyzerUsed": "FoundationModels (Apple Native)"
        ]
    }
}

// MARK: - Foundation Models Analyzer
@available(iOS 15.0, *)
class FoundationModelsAnalyzer {
    static let shared = FoundationModelsAnalyzer()
    
    private init() {
        print("[FoundationModelsAnalyzer] 🚀 Initialized with Apple Native APIs")
    }
    
    // MARK: - Availability Check
    static func isAvailable() -> Bool {
        if #available(iOS 18.2, *) {
            let deviceModel = getDeviceModel()
            let iosVersion = UIDevice.current.systemVersion
            
            print(String(repeating: "=", count: 60))
            print("[FoundationModelsAnalyzer] 🔍 Device Check")
            print(String(repeating: "=", count: 60))
            print("Device: \(deviceModel)")
            print("iOS: \(iosVersion)")
            
            // iPhone 15 Pro 이상
            let isSupported = 
                deviceModel.hasPrefix("iPhone15,3") ||   // 15 Pro
                deviceModel.hasPrefix("iPhone15,4") ||   // 15 Pro Max
                deviceModel.hasPrefix("iPhone16,") ||    // 16 Pro 시리즈
                deviceModel.hasPrefix("iPhone17,")       // 16 전체 시리즈
            
            print("Apple Intelligence Supported: \(isSupported)")
            print(String(repeating: "=", count: 60))
            
            return isSupported
        }
        
        return false
    }
    
    private static func getDeviceModel() -> String {
        var systemInfo = utsname()
        uname(&systemInfo)
        let machineMirror = Mirror(reflecting: systemInfo.machine)
        let identifier = machineMirror.children.reduce("") { identifier, element in
            guard let value = element.value as? Int8, value != 0 else { return identifier }
            return identifier + String(UnicodeScalar(UInt8(value)))
        }
        return identifier
    }
    
    // MARK: - Main Analysis Function
    func analyze(
        textBlocks: [[String: Any]],
        imageSize: [String: CGFloat]
    ) async throws -> AnalysisResult {
        
        print("[FoundationModelsAnalyzer] 🔍 Starting Analysis...")
        print("[FoundationModelsAnalyzer] Input blocks: \(textBlocks.count)")
        
        let fullText = textBlocks
            .compactMap { $0["text"] as? String }
            .joined(separator: "\n")
        
        print("[FoundationModelsAnalyzer] Full text length: \(fullText.count)")
        
        // 1. Filter UI Noise
        let filteredBlocks = filterUINoiseBlocks(textBlocks, imageSize: imageSize)
        let cleanText = filteredBlocks
            .compactMap { $0["text"] as? String }
            .joined(separator: "\n")
        
        print("[FoundationModelsAnalyzer] Filtered blocks: \(filteredBlocks.count)")
        
        // 2. Generate Summary using NLSummarizer
        let explanation = generateExplanation(cleanText)
        
        // 3. Extract Insights
        let insights = extractInsights(from: cleanText)
        
        // 4. Detect Structured Data
        let detectedData = detectStructuredData(in: fullText)
        
        // 5. Generate Tags
        let tags = generateTags(from: cleanText)
        
        // 6. Detect Content Type
        let contentType = detectContentType(cleanText)
        
        // 7. Generate Title
        let title = generateTitle(from: cleanText)
        
        let result = AnalysisResult(
            title: title,
            explanation: explanation,
            summary: explanation,
            insights: insights,
            tags: tags,
            contentType: contentType,
            refinedText: cleanText,
            detectedData: detectedData,
            provider: "foundation"
        )
        
        print("[FoundationModelsAnalyzer] ✅ Analysis Complete")
        print("[FoundationModelsAnalyzer]   - Title: \(title)")
        print("[FoundationModelsAnalyzer]   - Explanation: \(explanation.prefix(50))...")
        print("[FoundationModelsAnalyzer]   - Insights: \(insights.count)")
        print("[FoundationModelsAnalyzer]   - Tags: \(tags)")
        
        return result
    }
    
    // MARK: - 1. UI Noise Filtering
    private func filterUINoiseBlocks(
        _ blocks: [[String: Any]],
        imageSize: [String: CGFloat]
    ) -> [[String: Any]] {
        
        return blocks.filter { block in
            guard let text = block["text"] as? String,
                  let top = block["top"] as? Double else {
                return false
            }
            
            let confidence = block["confidence"] as? Double ?? 1.0
            let trimmed = text.trimmingCharacters(in: .whitespacesAndNewlines)
            
            // 1. 기본 필터 (완화됨)
            if trimmed.isEmpty { return false }
            if trimmed.count < 2 { return false }
            if top < 0.01 || top > 0.99 { return false }  // 완화: 0.03 → 0.01
            if confidence < 0.25 { return false }  // 완화: 0.5 → 0.25
            
            // 2. 상태바 텍스트 (시간, 배터리)
            if top < 0.05 && trimmed.count < 10 {
                if trimmed.range(of: "^\\d{1,2}:\\d{2}$", options: .regularExpression) != nil {
                    return false  // "2:57"
                }
                if trimmed.range(of: "^\\d{1,3}%?$", options: .regularExpression) != nil {
                    return false  // "100%"
                }
            }
            
            // 3. 순수 UI 버튼 (정확한 매칭만)
            let exactUIKeywords = [
                "로그인이 필요합니다", "로그인", "회원가입", "닫기", "취소",
                "내소식", "이웃목록", "통계", "글쓰기", "내 체크인",
                "최근 본 글", "내 동영상", "내 상품", "관리", "마켓 플레이스",
                "장바구니", "클립만들기", "My Menu 닫기"
            ]
            
            for keyword in exactUIKeywords {
                if trimmed == keyword {
                    print("[FoundationModelsAnalyzer] 🚫 Filtered exact UI: \(keyword)")
                    return false
                }
            }
            
            // 4. 메뉴 리스트 패턴 (짧고 연속된 단어들)
            if trimmed.count <= 6 {
                let menuKeywords = [
                    "홈", "소식", "메뉴", "상품권", "리뷰", "사진", "주변",
                    "출발", "도착", "주문", "배달", "포장", "매장",
                    "검색", "공유", "저장", "편집", "삭제"
                ]
                
                if menuKeywords.contains(trimmed) {
                    print("[FoundationModelsAnalyzer] 🚫 Filtered menu: \(trimmed)")
                    return false
                }
            }
            
            // 5. URL만 있는 라인 (하지만 URL 포함은 허용)
            if trimmed.range(of: "^https?://", options: .regularExpression) != nil &&
               trimmed.range(of: "\\s", options: .regularExpression) == nil {
                print("[FoundationModelsAnalyzer] 🚫 Filtered standalone URL")
                return false
            }
            
            // 6. 광고 마커
            if trimmed == "AD" || trimmed == "광고" {
                return false
            }
            
            print("[FoundationModelsAnalyzer] ✅ Kept: \(trimmed.prefix(50))...")
            return true
        }
    }
    
    // MARK: - 2. Generate Explanation (NLSummarizer)
    private func generateExplanation(_ text: String) -> String {
        guard !text.isEmpty else { 
            return "스크린샷 분석 결과가 없습니다."
        }
        
        // 너무 짧으면 그대로 반환
        if text.count < 50 {
            return text
        }
        
        // 문장 단위로 분리
        let sentences = text.components(separatedBy: CharacterSet(charactersIn: ".!?\n"))
            .map { $0.trimmingCharacters(in: .whitespaces) }
            .filter { $0.count > 10 }
        
        if sentences.isEmpty {
            return text.prefix(200).description
        }
        
        // 중요한 문장 선택 (최대 3개)
        let importantSentences = sentences
            .sorted { scoreSentence($0, in: text) > scoreSentence($1, in: text) }
            .prefix(3)
        
        let summary = importantSentences.joined(separator: " ")
        
        // Note: NLSummarizer doesn't exist in current iOS SDK
        // Using sentence-based summarization instead
        
        return summary.isEmpty ? text.prefix(200).description : summary
    }
    
    private func scoreSentence(_ sentence: String, in fullText: String) -> Double {
        var score = 0.0
        
        // 길이 점수 (30-150자가 이상적)
        if sentence.count >= 30 && sentence.count <= 150 {
            score += 3.0
        } else if sentence.count >= 20 && sentence.count <= 200 {
            score += 1.0
        }
        
        // 문장 부호로 끝남
        if sentence.last == "." || sentence.last == "다" || sentence.last == "요" {
            score += 1.5
        }
        
        // 숫자 포함 (구체적 정보)
        if sentence.range(of: "\\d", options: .regularExpression) != nil {
            score += 1.0
        }
        
        // 키워드 포함
        let importantKeywords = ["매장", "위치", "리뷰", "영업", "가격", "배달", "주문", "이용"]
        for keyword in importantKeywords {
            if sentence.contains(keyword) {
                score += 0.5
            }
        }
        
        return score
    }
    
    // MARK: - 3. Extract Insights
    private func extractInsights(from text: String) -> [String] {
        var insights: [String] = []
        
        // 영업 시간
        if let match = text.range(of: "\\d{1,2}:\\d{2}에 영업 종료", options: .regularExpression) {
            insights.append("영업 시간: " + String(text[match]))
        }
        
        // 주문 방법
        if text.contains("주문") {
            if let match = text.range(of: "[A-Z]\\s*주문", options: .regularExpression) {
                insights.append("주문 방법: " + String(text[match]))
            } else {
                insights.append("주문 방법: 온라인 주문 가능")
            }
        }
        
        // 배달/포장
        if text.contains("배달") || text.contains("포장") {
            var services: [String] = []
            if text.contains("배달") { services.append("배달") }
            if text.contains("포장") { services.append("포장") }
            if text.contains("단체") { services.append("단체") }
            insights.append(services.joined(separator: ", ") + " 이용 가능")
        }
        
        // 편의시설
        if text.contains("화장실") {
            insights.append("화장실 구분: 남/녀 구분")
        }
        if text.contains("무선 인터넷") || text.contains("Wi-Fi") || text.contains("와이파이") {
            insights.append("무선 인터넷 이용 가능")
        }
        
        // 가격
        if let match = text.range(of: "\\d{1,3}(,\\d{3})*원", options: .regularExpression) {
            insights.append("가격: " + String(text[match]))
        }
        
        // 날짜
        if let match = text.range(of: "\\d{4}년 \\d{1,2}월 \\d{1,2}일", options: .regularExpression) {
            insights.append("날짜: " + String(text[match]))
        }
        
        // 리뷰 수
        if let match = text.range(of: "리뷰\\s*\\d+", options: .regularExpression) {
            insights.append(String(text[match]))
        }
        
        return Array(insights.prefix(5))  // 최대 5개
    }
    
    // MARK: - 4. Detect Structured Data (NSDataDetector)
    private func detectStructuredData(in text: String) -> DetectedData {
        var urls: [String] = []
        var phoneNumbers: [String] = []
        var emails: [String] = []
        
        // Use specific types instead of .all
        let types: NSTextCheckingResult.CheckingType = [.link, .phoneNumber, .address, .date]
        guard let detector = try? NSDataDetector(types: types.rawValue) else {
            return DetectedData(urls: urls, phoneNumbers: phoneNumbers, emails: emails)
        }
        
        let matches = detector.matches(in: text, options: [], range: NSRange(text.startIndex..., in: text))
        
        for match in matches {
            if let url = match.url {
                urls.append(url.absoluteString)
            }
            if let phone = match.phoneNumber {
                phoneNumbers.append(phone)
            }
            if match.resultType == NSTextCheckingResult.CheckingType.link, let range = Range(match.range, in: text) {
                let matchText = String(text[range])
                if matchText.contains("@") {
                    emails.append(matchText)
                }
            }
        }
        
        print("[FoundationModelsAnalyzer] Detected data: URLs=\(urls.count), Phones=\(phoneNumbers.count), Emails=\(emails.count)")
        
        return DetectedData(
            urls: Array(Set(urls)),  // 중복 제거
            phoneNumbers: Array(Set(phoneNumbers)),
            emails: Array(Set(emails))
        )
    }
    
    // MARK: - 5. Generate Tags (NLTagger)
    private func generateTags(from text: String) -> [String] {
        guard !text.isEmpty else { return [] }
        
        let tagger = NLTagger(tagSchemes: [.lexicalClass])
        tagger.string = text
        
        var wordFreq: [String: Int] = [:]
        
        tagger.enumerateTags(in: text.startIndex..<text.endIndex,
                            unit: .word,
                            scheme: .lexicalClass,
                            options: [.omitWhitespace, .omitPunctuation]) { tag, range in
            if tag == .noun || tag == .personalName || tag == .placeName {
                let word = String(text[range])
                if word.count >= 2 && !isStopword(word) {
                    wordFreq[word, default: 0] += 1
                }
            }
            return true
        }
        
        // 빈도 기반 상위 태그
        let tags = wordFreq
            .filter { $0.value >= 1 }
            .sorted { $0.value > $1.value }
            .prefix(5)
            .map { $0.key }
        
        print("[FoundationModelsAnalyzer] Generated tags: \(tags)")
        
        return Array(tags)
    }
    
    private func isStopword(_ word: String) -> Bool {
        let stopwords = [
            "것", "수", "등", "및", "이", "그", "저", "더", "를", "을", "가", "이", "은", "는",
            "the", "a", "an", "and", "or", "but", "in", "on", "at", "to", "for"
        ]
        return stopwords.contains(word.lowercased())
    }
    
    // MARK: - 6. Detect Content Type
    private func detectContentType(_ text: String) -> String {
        let lowercased = text.lowercased()
        
        if lowercased.contains("주문") || lowercased.contains("배달") || lowercased.contains("리뷰") {
            return "place"
        }
        if lowercased.contains("대학") || lowercased.contains("학교") || lowercased.contains("교육") {
            return "education"
        }
        if lowercased.contains("뉴스") || lowercased.contains("기자") || lowercased.contains("발생") {
            return "news"
        }
        if lowercased.contains("코드") || lowercased.contains("api") || lowercased.contains("개발") {
            return "tech"
        }
        
        return "general"
    }
    
    // MARK: - 7. Generate Title
    private func generateTitle(from text: String) -> String {
        // 문장 단위로 분리
        let sentences = text.components(separatedBy: CharacterSet(charactersIn: "\n.!?"))
            .map { $0.trimmingCharacters(in: .whitespaces) }
            .filter { $0.count >= 5 && $0.count <= 100 }
        
        // 첫 번째 의미있는 문장 찾기
        for sentence in sentences.prefix(5) {
            // UI 키워드 체크
            let uiKeywords = ["로그인", "회원가입", "내소식", "통계", "최근 본"]
            let hasUIKeyword = uiKeywords.contains { sentence.contains($0) }
            
            if !hasUIKeyword && sentence.count >= 10 {
                return String(sentence.prefix(50))
            }
        }
        
        // Fallback: 가장 긴 문장
        if let longest = sentences.max(by: { $0.count < $1.count }), longest.count >= 10 {
            return String(longest.prefix(50))
        }
        
        return "New Memory"
    }
}
