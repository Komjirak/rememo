## 🚀 Step 7: OpenAI Provider 추가 (Optional)

### 7-1. OpenAI API 통합

**파일:** `ios/Runner/OpenAIAnalyzer.swift` (새로 생성)

```swift
import Foundation

class OpenAIAnalyzer {
    static let shared = OpenAIAnalyzer()
    private let apiKey = "YOUR_OPENAI_API_KEY"
    
    func analyze(textBlocks: [[String: Any]]) async throws -> AnalysisResult {
        let fullText = textBlocks.compactMap { $0["text"] as? String }.joined(separator: "\n")
        
        let url = URL(string: "https://api.openai.com/v1/chat/completions")!
        var request = URLRequest(url: url)
        request.httpMethod = "POST"
        request.setValue("Bearer \(apiKey)", forHTTPHeaderField: "Authorization")
        request.setValue("application/json", forHTTPHeaderField: "Content-Type")
        
        let body: [String: Any] = [
            "model": "gpt-4-turbo-preview",
            "messages": [
                [
                    "role": "user",
                    "content": """
                    Analyze this screenshot text and return JSON:
                    
                    \(fullText)
                    
                    Return:
                    {
                      "title": "...",
                      "explanation": "...",
                      "insights": ["...", "...", "..."],
                      "tags": ["...", "..."]
                    }
                    """
                ]
            ]
        ]
        
        request.httpBody = try JSONSerialization.data(withJSONObject: body)
        
        let (data, _) = try await URLSession.shared.data(for: request)
        // Parse and return...
    }
}
```

### 7-2. ContentAnalyzerAdapter에서 Provider 선택

```swift
func analyze(textBlocks: [[String: Any]], imageSize: [String: CGFloat]) async -> [String: Any] {
    let prefs = UserDefaults.standard
    let selectedProvider = prefs.string(forKey: "ai_provider") ?? "apple"
    
    if selectedProvider == "openai" {
        return try await OpenAIAnalyzer.shared.analyze(textBlocks: textBlocks).toDict()
    } else {
        return try await FoundationModelsAnalyzer.shared.analyze(...).toDict()
    }
}
```

